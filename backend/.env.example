# ローカル開発: SQLite（サーバー不要、デフォルト）
DATABASE_URL="file:./dev.db"

# 本番: AWS RDS MySQL の場合は schema.prisma の provider を mysql に変更
# DATABASE_URL="mysql://user:password@your-rds-endpoint:3306/vehicle_pl"

# CORS 許可オリジン（フロントエンドの URL）
# 開発時: http://localhost:3000
# 本番: https://your-frontend-domain.com
CORS_ORIGIN="http://localhost:3000"

# サーバーポート（デフォルト: 4000）
# PORT=4000
